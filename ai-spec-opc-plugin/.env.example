# AI-Spec OPC Plugin 环境变量配置

# docspec-server 地址
# 例如：http://localhost:4000 或 https://docspec.example.com
DOCSPEC_SERVER_URL=http://localhost:4000

# docspec-server 管理员 Token
# 通过 docspec-server 的 /api/auth/token 接口获取
DOCSPEC_ADMIN_TOKEN=

# OPC 系统地址（可选，用于本地开发测试）
# OPC_API_URL=http://localhost:3100

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info
