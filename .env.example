# docspec-server 环境变量示例
# 复制此文件为 .env 并填入真实值

# 服务端口
PORT=4000

# JWT 签发密钥（生产环境请使用强随机字符串）
JWT_SECRET=change-me-in-production

# douhua-spec 仓库根目录绝对路径
SPEC_REPO_PATH=D:/GitHub/Douhua/douhua-spec

# 权限配置文件路径（相对于 SPEC_REPO_PATH）
PERMISSIONS_FILE=.spec-permissions.yaml

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# GitLab 配置（用于创建 MR，可选）
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-your-personal-access-token
GITLAB_SPEC_REPO_ID=your-group/douhua-spec

# Token 签发密钥（/api/auth/token 接口使用）
TOKEN_ISSUE_SECRET=change-me-in-production
